{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "A Map of Modern Cinema",
    "subtitle": "Film production by country, 1970–2024",
    "anchor": "start",
    "fontSize": 22,
    "subtitleFontSize": 13,
    "subtitleColor": "#6b6258",
    "font": "Playfair Display",
    "subtitleFont": "Inter"
  },
  "width": 900,
  "height": 480,
  "background": null,
  "config": {
    "view": {"stroke": null},
    "font": "Inter"
  },
  "projection": {"type": "equalEarth"},
  "layer": [
    {
      "data": {
        "sphere": true
      },
      "mark": {
        "type": "geoshape",
        "fill": "#A8CBDD"
      }
    },
    
    {
      "data": {
        "url": "https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json",
        "format": {"type": "topojson", "feature": "countries"}
      },
      "mark": {
        "type": "geoshape",
        "fill": "#e8e2d5",
        "stroke": "#ffffff",
        "strokeWidth": 0.5
      }
    },
    {
      "data": {
        "url": "https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json",
        "format": {"type": "topojson", "feature": "countries"}
      },
      "transform": [
        {
          "lookup": "properties.name",
          "from": {
            "data": {"url": "data/films_by_country.csv"},
            "key": "country",
            "fields": ["film_count", "avg_rating", "total_revenue"]
          }
        },
        {"filter": "datum.film_count != null"}
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 0.5
      },
      "encoding": {
        "color": {
          "field": "film_count",
          "type": "quantitative",
          "scale": {
            "type": "log",
            "scheme": "reds",
            "domain": [1, 10000]
          },
          "legend": {
            "title": "Number of Films Produced",
            "orient": "bottom",
            "direction": "horizontal",
            "gradientLength": 320,
            "offset": 20,
            "titleFontSize": 11,
            "labelFontSize": 10
          }
        },
        "tooltip": [
          {"field": "properties.name", "type": "nominal", "title": "Country"},
          {"field": "film_count", "type": "quantitative", "title": "Number of Films", "format": ","},
          {"field": "avg_rating", "type": "quantitative", "title": "Average Rating", "format": ".2f"},
          {"field": "total_revenue", "type": "quantitative", "title": "Total Revenue (USD)", "format": "$,.0f"}
        ]
      }
    },
    {
      "data": {
        "values": [
          {"country": "United States", "lon": -98, "lat": 39, "label": "USA"},
          {"country": "Canada", "lon": -106, "lat": 56, "label": "Canada"},
          {"country": "United Kingdom", "lon": -2, "lat": 54, "label": "UK"},
          {"country": "France", "lon": 2, "lat": 47, "label": "France"},
          {"country": "Germany", "lon": 10, "lat": 51, "label": "Germany"},
          {"country": "Italy", "lon": 12, "lat": 43, "label": "Italy"},
          {"country": "Japan", "lon": 138, "lat": 36, "label": "Japan"},
          {"country": "India", "lon": 79, "lat": 22, "label": "India"},
          {"country": "Australia", "lon": 134, "lat": -25, "label": "Australia"},
          {"country": "Brazil", "lon": -53, "lat": -10, "label": "Brazil"},
          {"country": "South Korea", "lon": 128, "lat": 36, "label": "S. Korea"},
          {"country": "China", "lon": 104, "lat": 35, "label": "China"}
        ]
      },
      "mark": {
        "type": "text",
        "fontSize": 11,
        "fontWeight": "bold",
        "color": "white"
      },
      "encoding": {
        "longitude": {"field": "lon", "type": "quantitative"},
        "latitude": {"field": "lat", "type": "quantitative"},
        "text": {"field": "label", "type": "nominal"}
      }
    }
  ]
}