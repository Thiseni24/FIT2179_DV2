{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "A Map of Modern Cinema",
    "subtitle": "Film production by country, 1970–2024",
    "anchor": "start",
    "fontSize": 22,
    "subtitleFontSize": 13,
    "subtitleColor": "#6b6258",
    "font": "Playfair Display",
    "subtitleFont": "Inter"
  },
  "width": 900,
  "height": 480,
  "background": null,
  "config": {
    "view": {"stroke": null},
    "font": "Inter"
  },
  "projection": {"type": "equalEarth"},
  "layer": [
    {
      "data": {"sphere": true},
      "mark": {
        "type": "geoshape",
        "fill": "#A8CBDD"
      }
    },
    {
      "data": {
        "url": "https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json",
        "format": {"type": "topojson", "feature": "countries"}
      },
      "mark": {
        "type": "geoshape",
        "fill": "#e8e2d5",
        "stroke": "#ffffff",
        "strokeWidth": 0.5
      }
    },
    {
      "data": {
        "url": "https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json",
        "format": {"type": "topojson", "feature": "countries"}
      },
      "transform": [
        {
          "lookup": "properties.name",
          "from": {
            "data": {"url": "data/films_by_country.csv"},
            "key": "country",
            "fields": ["film_count", "avg_rating", "total_revenue"]
          }
        },
        {
          "filter": "datum.film_count != null && datum.film_count > 0"
        }
      ],
      "mark": {
        "type": "geoshape",
        "stroke": "#ffffff",
        "strokeWidth": 0.5
      },
      "encoding": {
        "color": {
          "field": "film_count",
          "type": "quantitative",
          "scale": {
            "type": "log",
            "range": ["#f2d6d0", "#e0999a", "#a7627c", "#491734"],
            "interpolate": "lab"
          },
          "legend": {
            "title": "Number of Films Produced",
            "orient": "bottom",
            "direction": "horizontal",
            "gradientLength": 320,
            "offset": 20,
            "titleFontSize": 11,
            "labelFontSize": 10
          }
        },
        "tooltip": [
          {
            "field": "properties.name",
            "type": "nominal",
            "title": "Country"
          },
          {
            "field": "film_count",
            "type": "quantitative",
            "title": "Number of Films",
            "format": ","
          },
          {
            "field": "avg_rating",
            "type": "quantitative",
            "title": "Average Rating",
            "format": ".2f"
          },
          {
            "field": "total_revenue",
            "type": "quantitative",
            "title": "Total Revenue (USD)",
            "format": "$,.0f"
          }
        ]
      }
    }
  ]
}