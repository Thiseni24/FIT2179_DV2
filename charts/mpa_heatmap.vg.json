{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "title": {
    "text": "How Do Movie Certifications Differ?",
    "subtitle": "Darker colours indicate higher average values within each metric",
    "anchor": "start",
    "fontSize": 18,
    "subtitleFontSize": 12
  },

  "width": 420,
  "height": 300,

  "data": {
    "url": "data/movies_joined.csv"
  },

  "transform": [
    {
      "filter": "datum.mpaa != null && datum.mpaa != '' && datum.mpaa != 'Null' && datum.mpaa != 'Not Rated' && datum.mpaa != 'Unrated'"
    },

    {
      "joinaggregate": [
        {
          "op": "count",
          "as": "MovieCount"
        }
      ],
      "groupby": ["mpaa"]
    },

    {
      "filter": "datum.MovieCount >= 10"
    },

    {
      "aggregate": [
        {
          "op": "mean",
          "field": "popularity",
          "as": "Average Popularity"
        },
        {
          "op": "mean",
          "field": "imdb_rating",
          "as": "Average IMDb Rating"
        },
        {
          "op": "mean",
          "field": "runtime_min",
          "as": "Average Runtime"
        },
        {
          "op": "count",
          "as": "Number of Titles"
        }
      ],
      "groupby": ["mpaa"]
    },

    {
      "fold": [
        "Average Popularity",
        "Average IMDb Rating",
        "Average Runtime"
      ],
      "as": ["Metric", "Value"]
    },

    {
      "joinaggregate": [
        {
          "op": "min",
          "field": "Value",
          "as": "MinValue"
        },
        {
          "op": "max",
          "field": "Value",
          "as": "MaxValue"
        }
      ],
      "groupby": ["Metric"]
    },

    {
      "calculate": "(datum.Value - datum.MinValue) / (datum.MaxValue - datum.MinValue)",
      "as": "NormalisedValue"
    },

    {
      "calculate": "datum.Metric == 'Average Runtime' ? format(datum.Value, '.1f') + ' min' : format(datum.Value, '.1f')",
      "as": "ValueLabel"
    }
  ],

  "layer": [
    {
      "mark": {
        "type": "rect",
        "cornerRadius": 0,
        "stroke": "#f5f5f5",
        "strokeWidth": 0.5
      },

      "encoding": {
        "x": {
          "field": "Metric",
          "type": "nominal",
          "sort": [
            "Average Popularity",
            "Average IMDb Rating",
            "Average Runtime"
          ],
          "axis": {
            "title": null,
            "labelAngle": 0,
            "labelFontSize": 11
          }
        },

        "y": {
          "field": "mpaa",
          "type": "ordinal",
          "axis": {
            "title": "Movie Certification",
            "labelFontSize": 11
          }
        },

        "color": {
          "field": "NormalisedValue",
          "type": "quantitative",
          "scale": {
            "range": [
                "#FFFBEA",
                "#FFE8A3",
                "#FFD43B",
                "#FAB005",
                "#D97706"
            ]
          },
          "legend": {
            "title": "Relative Average"
          }
        },

        "tooltip": [
          {
            "field": "mpaa",
            "title": "Certification"
          },
          {
            "field": "Metric"
          },
          {
            "field": "Value",
            "title": "Average Value",
            "format": ".2f"
          },
          {
            "field": "Number of Titles",
            "title": "Number of Titles"
          }
        ]
      }
    },

    {
      "mark": {
        "type": "text",
        "fontSize": 12,
        "fontWeight": "normal",
        "color": "black"
      },

      "encoding": {
        "x": {
          "field": "Metric",
          "type": "nominal",
          "sort": [
            "Average Popularity",
            "Average IMDb Rating",
            "Average Runtime"
          ]
        },

        "y": {
          "field": "mpaa",
          "type": "ordinal"
        },

        "text": {
          "field": "ValueLabel"
        }
      }
    }
  ],

  "config": {
    "view": {
      "stroke": null
    },

    "axis": {
      "domain": false,
      "tickColor": "#cccccc"
    }
  }
}