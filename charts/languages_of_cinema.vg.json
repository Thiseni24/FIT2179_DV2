{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Languages of Cinema",
    "subtitle": "Share of films by original language, 1970–2024",
    "anchor": "start",
    "fontSize": 20,
    "subtitleFontSize": 13,
    "subtitleColor": "#6b6258",
    "font": "Playfair Display",
    "subtitleFont": "Inter"
  },
  "width": 650,
  "height": 360,
  "background": null,
  "data": {
    "url": "data/tmdb.csv",
    "format": {
      "type": "csv",
      "parse": {
        "year": "number"
      }
    }
  },
  "transform": [
    {
      "filter": "datum.year >= 1970 && datum.year <= 2024 && datum.original_language != null"
    },
    {
      "calculate": "indexof(['en','fr','es','ja','ko','hi','de','it','zh'], datum.original_language) >= 0 ? datum.original_language : 'Other'",
      "as": "language_grouped"
    },
    {
      "calculate": "datum.language_grouped == 'en' ? 'English' : datum.language_grouped == 'fr' ? 'French' : datum.language_grouped == 'es' ? 'Spanish' : datum.language_grouped == 'ja' ? 'Japanese' : datum.language_grouped == 'ko' ? 'Korean' : datum.language_grouped == 'hi' ? 'Hindi' : datum.language_grouped == 'de' ? 'German' : datum.language_grouped == 'it' ? 'Italian' : datum.language_grouped == 'zh' ? 'Chinese' : 'Other'",
      "as": "language_label"
    },
    {
      "calculate": "datum.language_grouped == 'en' ? 1 : datum.language_grouped == 'fr' ? 2 : datum.language_grouped == 'es' ? 3 : datum.language_grouped == 'it' ? 4 : datum.language_grouped == 'ja' ? 5 : datum.language_grouped == 'hi' ? 6 : datum.language_grouped == 'ko' ? 7 : datum.language_grouped == 'de' ? 8 : datum.language_grouped == 'zh' ? 9 : 10",
      "as": "language_order"
    }
  ],
  "mark": {
    "type": "area",
    "interpolate": "monotone"
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "quantitative",
      "axis": {
        "title": "Release Year",
        "format": "d",
        "grid": true,
        "gridColor": "#ebe1d2",
        "gridDash": [2, 3]
      }
    },
    "y": {
      "aggregate": "count",
      "type": "quantitative",
      "stack": "normalize",
      "axis": {
        "title": "Share of Films",
        "format": "%"
      }
    },
    "color": {
      "field": "language_label",
      "type": "nominal",
      "title": "Original Language",
      "scale": {
        "domain": [
          "English",
          "French",
          "Spanish",
          "Italian",
          "Japanese",
          "Hindi",
          "Korean",
          "German",
          "Chinese",
          "Other"
        ],
        "range": [
          "#8C564B",
          "#4E79A7",
          "#F28E2B",
          "#B07AA1",
          "#76B7B2",
          "#EDC948",
          "#9C755F",
          "#BAB0AC",
          "#A0CBE8",
          "#D8CBBB"
        ]
      }
    },
    "order": {
      "field": "language_order",
      "type": "ordinal",
      "sort": "ascending"
    },
    "tooltip": [
      {
        "field": "year",
        "type": "quantitative",
        "title": "Year",
        "format": "d"
      },
      {
        "field": "language_label",
        "type": "nominal",
        "title": "Language"
      },
      {
        "aggregate": "count",
        "type": "quantitative",
        "title": "Number of Films"
      }
    ]
  },
  "config": {
    "view": {"stroke": null},
    "font": "Inter",
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "labelColor": "#1a1a1a",
      "titleColor": "#6b6258",
      "labelFontSize": 11,
      "titleFontSize": 11,
      "domain": false,
      "ticks": false,
      "grid": false
    },
    "legend": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "labelFontSize": 11,
      "titleFontSize": 12
    }
  }
}