{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": {
    "text": "Genre Tides in Global Cinema",
    "subtitle": "How the seven most-produced film genres have grown and shifted, 1970–2024",
    "anchor": "start",
    "fontSize": 20,
    "subtitleFontSize": 13,
    "subtitleColor": "#6b6258",
    "font": "Playfair Display",
    "subtitleFont": "Inter"
  },
  "width": 650,
  "height": 380,
  "background": null,
  "params": [
    {
      "name": "GenreFilter",
      "bind": {
        "input": "select",
        "options": ["All","Drama","Comedy","Action","Horror","Animation","Thriller","Crime","Other"],
        "name": "Filter Genre:  "
      },
      "value": "All"
    }
  ],
  "config": {
    "view": {"stroke": null},
    "font": "Inter",
    "axis": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "labelColor": "#1a1a1a",
      "titleColor": "#6b6258",
      "labelFontSize": 11,
      "titleFontSize": 11,
      "domain": false,
      "ticks": false,
      "grid": false
    },
    "legend": {
      "labelFont": "Inter",
      "titleFont": "Inter",
      "labelFontSize": 11,
      "titleFontSize": 12
    }
  },
  "data": {
    "url": "data/tmdb.csv",
    "format": {
      "type": "csv",
      "parse": {"year": "number"}
    }
  },
  "transform": [
    {"filter": "datum.year >= 1970 && datum.year <= 2024 && datum.tmdb_primary_genre != null"},
    {
      "calculate": "indexof(['Drama','Comedy','Action','Horror','Animation','Thriller','Crime'], datum.tmdb_primary_genre) >= 0 ? datum.tmdb_primary_genre : 'Other'",
      "as": "genre_grouped"
    },
    {"filter": "GenreFilter == 'All' || datum.genre_grouped == GenreFilter"}
  ],
  "mark": {
    "type": "area",
    "interpolate": "monotone"
  },
  "encoding": {
    "x": {
      "field": "year",
      "type": "quantitative",
      "scale": {"domain": [1970, 2024]},
      "axis": {
        "title": "Release Year",
        "format": "d",
        "grid": true,
        "gridColor": "#ebe1d2",
        "gridDash": [2, 3]
      }
    },
    "y": {
      "aggregate": "count",
      "type": "quantitative",
      "stack": "center",
      "axis": null
    },
    "color": {
      "field": "genre_grouped",
      "type": "nominal",
      "title": "Genre",
      "scale": {
        "domain": ["Drama","Comedy","Action","Horror","Animation","Thriller","Crime","Other"],
        "range": ["#7a2e3e","#d4a017","#d65a1f","#2c2c2c","#5a7fa5","#3a4d6c","#2d6166","#9b9085"]
      },
      "legend": {
        "orient": "right",
        "titleFontSize": 12,
        "labelFontSize": 11
      }
    },
    "tooltip": [
      {"field": "year", "type": "quantitative", "title": "Year", "format": "d"},
      {"field": "genre_grouped", "type": "nominal", "title": "Genre"},
      {"aggregate": "count", "type": "quantitative", "title": "Number of Films"}
    ]
  }
}